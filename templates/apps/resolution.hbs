<form class="to-change resolution">

  {{#if isSetup}}
  <section class="resolution-setup">
    <p class="hint">{{localize "TOCHANGE.Resolution.setupHint"}}</p>

    <div class="attr-pick">
      {{#each attrChoices}}
      <button type="button" class="attr-btn {{#if this.selected}}active{{/if}}"
              data-attr="{{this.key}}" title="{{this.label}}">
        <span class="abbr">{{this.abbr}}</span>
        <span class="name">{{this.label}}</span>
      </button>
      {{/each}}
    </div>

    <div class="assist-row">
      <label>{{localize "TOCHANGE.Resolution.assist"}}</label>
      <div class="assist-stepper">
        <button type="button" class="assist-step" data-assist-step="-1"
                aria-label="−" {{#unless assist}}disabled{{/unless}}>
          <i class="fas fa-minus"></i>
        </button>
        <span class="assist-value">{{assist}}</span>
        <button type="button" class="assist-step" data-assist-step="1"
                aria-label="+" {{#if assistAtMax}}disabled{{/if}}>
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>

    <div class="draw-breakdown">
      <div class="dd"><span>{{localize "TOCHANGE.Resolution.base"}}</span><b>{{draw.base}}</b></div>
      <div class="dd"><span>{{localize "TOCHANGE.Resolution.assist"}}</span><b>+{{draw.assist}}</b></div>
      {{#if draw.tower}}<div class="dd tower"><span>{{localize "TOCHANGE.Resolution.tower"}}</span><b>+{{draw.tower}}</b></div>{{/if}}
      {{#if draw.justice}}<div class="dd justice"><span>{{localize "TOCHANGE.Resolution.justice"}}</span><b>+{{draw.justice}}</b></div>{{/if}}
      <div class="dd total"><span>{{localize "TOCHANGE.Resolution.total"}}</span><b>{{draw.total}}</b></div>
    </div>


    <footer class="resolution-actions">
      <button type="button" data-action="draw" {{#unless draw.total}}disabled{{/unless}}>
        <i class="fas fa-layer-group"></i> {{localize "TOCHANGE.Resolution.draw"}}
      </button>
      {{#if canSuccumb}}
      <button type="button" class="succumb" data-action="succumb">
        <i class="fas fa-yin-yang"></i> {{localize "TOCHANGE.Resolution.succumb"}}
      </button>
      {{/if}}
      <button type="button" data-action="cancel">{{localize "TOCHANGE.Common.cancel"}}</button>
    </footer>
  </section>
  {{/if}}

  {{#if isReveal}}
  <section class="resolution-reveal">
    <p class="hint">{{localize "TOCHANGE.Resolution.revealHint"}}</p>

    {{#each triggers}}
    <p class="trigger-note"><i class="fas fa-bolt"></i> {{this}}</p>
    {{/each}}

    <div class="card-grid">
      {{#each drawn}}
      <div class="future-card {{#unless this.selectable}}locked{{/unless}}"
           {{#if this.selectable}}data-card="{{this.num}}"{{/if}}>
        <img src="{{this.img}}" alt="{{this.zh}}"/>
        <div class="card-cap">
          <span class="roman">{{this.roman}}</span>
          <span class="zh">{{this.zh}}</span>
        </div>
        <div class="card-effect">{{this.effectText}}</div>
        {{#unless this.selectable}}
        <div class="card-lock"><i class="fas fa-lock"></i> {{localize "TOCHANGE.Resolution.deathLockedShort"}}</div>
        {{/unless}}
      </div>
      {{/each}}
    </div>

    <footer class="resolution-actions">
      {{#if isGM}}
      <button type="button" class="deck-view-btn" data-action="deck-view">
        <i class="fas fa-eye"></i> {{localize "TOCHANGE.Resolution.deckView"}}
      </button>
      {{/if}}
      {{#if canSuccumb}}
      <button type="button" class="succumb" data-action="succumb">
        <i class="fas fa-yin-yang"></i> {{localize "TOCHANGE.Resolution.succumb"}}
      </button>
      {{/if}}
      <button type="button" data-action="cancel">{{localize "TOCHANGE.Common.cancel"}}</button>
    </footer>
  </section>
  {{/if}}
  <section class="free-draw">
      <p class="free-draw-head">
        <i class="fas fa-hand-sparkles"></i> {{localize "TOCHANGE.Resolution.freeDrawTitle"}}
      </p>
      <p class="hint">{{localize "TOCHANGE.Resolution.freeDrawHint"}}</p>
      <div class="free-draw-row">
        <div class="free-end">
          <button type="button" class="free-end-btn {{#if freeTop}}active{{/if}}" data-free-end="top">
            <i class="fas fa-angles-up"></i> {{localize "TOCHANGE.Resolution.freeTop"}}
          </button>
          <button type="button" class="free-end-btn {{#if freeBottom}}active{{/if}}" data-free-end="bottom">
            <i class="fas fa-angles-down"></i> {{localize "TOCHANGE.Resolution.freeBottom"}}
          </button>
        </div>
        <div class="free-count">
          <label>{{localize "TOCHANGE.Resolution.freeCount"}}</label>
          <div class="assist-stepper">
            <button type="button" class="assist-step" data-free-step="-1"
                    aria-label="−" {{#if freeCountAtMin}}disabled{{/if}}>
              <i class="fas fa-minus"></i>
            </button>
            <span class="assist-value">{{freeCount}}</span>
            <button type="button" class="assist-step" data-free-step="1"
                    aria-label="+" {{#if freeCountAtMax}}disabled{{/if}}>
              <i class="fas fa-plus"></i>
            </button>
          </div>
        </div>
        <button type="button" class="free-draw-btn" data-action="free-draw">
          <i class="fas fa-wand-magic-sparkles"></i> {{localize "TOCHANGE.Resolution.freeDraw"}}
        </button>
      </div>
    </section>

</form>
